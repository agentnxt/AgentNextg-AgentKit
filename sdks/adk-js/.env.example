# ===========================================
# WHATSAPP AI ASSISTANT - DOCKER ENVIRONMENT
# ===========================================

# WhatsApp Integration (REQUIRED)
GREEN_API_INSTANCE_ID=your_green_api_instance_id
GREEN_API_ACCESS_KEY=your_green_api_access_token

# AI Services (REQUIRED)
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_openai_organization_id

# Search APIs (REQUIRED)
SERPER_API_KEY=your_serper_dev_api_key
SERPAPI_API_KEY=your_serpapi_key

# WordPress Publishing (OPTIONAL)
WORDPRESS_USERNAME=your_wordpress_username
WORDPRESS_APP_PWD=your_wordpress_application_password
WORDPRESS_URL=https://your-wordpress-site.com

# Business Configuration
BUSINESS_DOMAIN=Your Business Name
BUSINESS_DESCRIPTION=Description of your business

# File Management
KNOWLEDGE_BASE_PATH=/app/knowledge_base
UPLOAD_TEMP_PATH=/app/temp_uploads

# Performance and Limits
OPENAI_RPM_LIMIT=3000
SERPER_RATE_LIMIT=100
SERPAPI_RATE_LIMIT=100
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30

# WordPress Configuration
DEFAULT_POST_STATUS=draft
DEFAULT_POST_CATEGORY=AI-Assistant
WORDPRESS_MEDIA_FOLDER=uploads/whatsapp-assistant

# Logging and Monitoring
LOG_LEVEL=INFO
WEBHOOK_SECRET=your_webhook_secret_key

# Docker-specific
CONTAINER_TIMEZONE=UTC
PYTHONPATH=/app

# Optional: Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Optional: Database Configuration
DATABASE_URL=sqlite:///./data/whatsapp_assistant.db
