# === Gateway mode ===
# managed: role-scoped keys, all traffic through llm.openautonomyx.com (tracked)
# byo:     customer provides own Anthropic + local model (no tracking)
GATEWAY_MODE=managed

# === Gateway config (managed mode only) ===
GATEWAY_URL=https://llm.openautonomyx.com
# Admin key — server-side only, used by /usage to call /spend/logs
GATEWAY_ADMIN_KEY=sk-litellm-admin-...

# Role-scoped virtual keys. Each is restricted at the gateway to a specific
# model allowlist and budget. Shared blast radius is halved — a compromised
# worker can't call Claude, a misbehaving reviewer can't call local models.
#
# Both keys should belong to the same LiteLLM "team" so spend rolls up to
# one tenant bill. See scripts/provision-tenant.sh.
CLAUDE_VIRTUAL_KEY=sk-litellm-claude-...
WORKER_VIRTUAL_KEY=sk-litellm-worker-...

# === Claude (reviewer) ===
CLAUDE_MODEL=claude-opus-4-7
# In managed mode these are auto-wired from CLAUDE_VIRTUAL_KEY at startup.
# In byo mode, set ANTHROPIC_API_KEY to a real Anthropic key and leave
# ANTHROPIC_BASE_URL unset.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# === Worker (worker) ===
LLM_BASE_URL=https://llm.openautonomyx.com/v1
LLM_MODEL=openai/qwen2.5-coder:32b
# In managed mode LLM_API_KEY is auto-wired from WORKER_VIRTUAL_KEY.
# In byo mode set explicitly.
LLM_API_KEY=

# Command template used to launch each worker.
WORKER_CMD=python -m worker.core.main -t "{task}"
WORKSPACES_DIR=./workspaces
MAX_CONCURRENT_AGENTS=3
AGENT_TIMEOUT_SECONDS=600

# === FastAPI server ===
HOST=0.0.0.0
PORT=8080
# Public URL of this service (used for Slack button links, GitHub PR links)
PUBLIC_URL=https://developers.agnxxt.com

# === SQLite (task/session metadata; cost data lives in gateway) ===
DATABASE_PATH=./review_sessions.db

# === Slack integration ===
# Create a Slack app at https://api.slack.com/apps with Socket Mode enabled.
# Bot token scopes: chat:write, commands, app_mentions:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Optional: restrict to specific channels (comma-separated IDs). Empty = any.
SLACK_ALLOWED_CHANNELS=

# === GitHub App integration ===
# Register a GitHub App; grant pull_requests:read, issues:write, contents:read.
# Subscribe to: issue_comment events.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=
# The comment prefix that triggers a review (default: /review)
GITHUB_TRIGGER_COMMAND=/review
